APP_NAME="NBIS Backend"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------
# Database — MySQL
# -----------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nbis
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

VITE_USE_DEV_SERVER=false
VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------
# Admin/Nurse/Police seeder credentials
# -----------------------------------------------------------------------
ADMIN_EMAIL=admin@nbis.com
ADMIN_NAME="System Admin"
ADMIN_PHONE=+201000000001
ADMIN_PASSWORD=Admin@1234

NURSE_EMAIL=nurse@nbis.com
NURSE_NAME="Nurse Sarah"
NURSE_PHONE=+201000000002
NURSE_PASSWORD=Nurse@1234

POLICE_EMAIL=police@nbis.com
POLICE_NAME="Officer Ahmed"
POLICE_PHONE=+201000000003
POLICE_PASSWORD=Police@1234

# -----------------------------------------------------------------------
# Footprint AI (FastAPI)
# -----------------------------------------------------------------------
FOOTPRINT_AI_URL=https://your-ai-service-url.com

# -----------------------------------------------------------------------
# Sanctum / Session / CORS
# -----------------------------------------------------------------------
SANCTUM_EXPIRATION=4320
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:5173,127.0.0.1,127.0.0.1:8000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,*
CORS_SUPPORTS_CREDENTIALS=true
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
